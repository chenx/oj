class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        n = len(nums)
        if n == 0:
            return []
        
        A = [0] * n
        B = [0] * n

        A[0] = nums[0]
        for i in range(1, n):
            A[i] = nums[i] * A[i-1]
        
        B[n-1] = nums[n-1]
        for i in range(n-2, -1, -1):
            B[i] = nums[i] * B[i+1]
        
        # [1,2,3,4]
        # A: [1,2,6,24]
        # B: [24,24,12,4]
        # result: [24, 12, 8, 6]
        result = [0] * n
        result[0] = B[1]
        result[n-1] = A[n-2]
        for i in range(1, n-1):
            result[i] = A[i-1] * B[i+1]
        return result

